Quickstart:
cd contracts
npm install
cp .env.example .env   # add PRIVATE_KEY + RPC keys
npm run compile
# local: npx hardhat node   (in another terminal)
npm run deploy
# testnets:
npx hardhat run scripts/deploy.ts --network sepolia
npx hardhat run scripts/deploy.ts --network base
